# JWT Configuration

quarkus.smallrye-jwt.enabled=true
mp.jwt.verify.publickey.location=classpath:/publicKey.pem
mp.jwt.verify.issuer=https://your-app.com
smallrye.jwt.sign.key.location=classpath:/privateKey.pem

# Token expiration
app.jwt.duration=3600

# S?curit?
quarkus.security.users.embedded.enabled=false
quarkus.security.auth.enabled-in-dev-mode=true

# CORS avec auth
quarkus.http.cors=true
quarkus.http.cors.origins=${ALLOWED_ORIGINS:http://localhost:5173}
#quarkus.http.cors.origins=${ALLOWED_ORIGINS:https://stvuebilling28691.z6.web.core.windows.net}
quarkus.http.cors.headers=accept,authorization,content-type,x-requested-with
quarkus.http.cors.methods=GET,POST,PUT,DELETE,OPTIONS,PATCH
quarkus.http.cors.credentials=true
